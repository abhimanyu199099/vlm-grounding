# -----------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/

# virtual environments
.venv/
venv/
env/
ENV/

# -----------------------------------------
# jupyter
# -----------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------
# os / editor
# -----------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

