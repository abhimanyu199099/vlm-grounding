# HuggingFace datasets cache
# -----------------------------------------
.cache/
cache/
*.pt.cache

# -----------------------------------------
# model weights and checkpoints
# -----------------------------------------
checkpoints/
*.pt
*.pth
*.bin
*.safetensors

# -----------------------------------------
# training runs and logs
# -----------------------------------------
runs/
wandb/
lightning_logs/
*.tfevents.*

# -----------------------------------------
